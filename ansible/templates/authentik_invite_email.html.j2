<!doctype html>
<html>
  <body style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;max-width:600px;margin:0 auto;padding:24px;color:#1a1a1a;">
    <h2>You're invited to the Chronobyte Homelab</h2>
    <p>Hey,</p>
    <p>You've been invited to create an account on the Chronobyte Homelab.
       Click the button below to choose a username, display name, and password.
       You'll then be able to access shared services like Jellyfin.</p>
    <p style="margin:32px 0;">
      <a href="{{ invite_url | e }}"
         style="background:#fd4b2d;color:#fff;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:600;">
        Accept invitation &amp; sign up
      </a>
    </p>
    <p style="font-size:13px;color:#555;">Or copy this link into your browser:<br>
      <a href="{{ invite_url | e }}">{{ invite_url | e }}</a>
    </p>
    <p style="font-size:13px;color:#555;">
      This invitation expires on <strong>{{ invite_expires | e }}</strong> and can only be used once.
    </p>
    <hr style="border:none;border-top:1px solid #eee;margin:24px 0;">
    <p style="font-size:12px;color:#999;">
      If you weren't expecting this email, you can safely ignore it.
    </p>
  </body>
</html>
